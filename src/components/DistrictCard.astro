---
/**
 * DistrictCard.astro — Compact card for homepage grid.
 * Shows district number, council member, key neighborhoods,
 * and one distinguishing stat from the current_vintage snapshot.
 */
interface Props {
  district: any;
}

const { district } = Astro.props;

const d = district;
const snap = d.demographics.snapshots.find(
  (s: any) => s.vintage === d.demographics.current_vintage
);
const data = snap?.data;

// Pick a distinguishing stat: population if available, else median income
const statLabel = data?.total_population ? 'Population' : 'Median Income';
const statValue = data?.total_population
  ? data.total_population.toLocaleString('en-US')
  : data?.median_hh_income_est
    ? '$' + data.median_hh_income_est.toLocaleString('en-US')
    : '—';

// Show first 3 neighborhoods
const neighborhoods = d.neighborhoods?.slice(0, 3) ?? [];
const base = import.meta.env.BASE_URL;
---
<a href={`${base}districts/${d.slug}/`} class="district-card">
  <div class="card-number">District {d.number}</div>
  <div class="card-member">{d.councilMember?.name ?? 'TBD'}</div>
  <div class="card-neighborhoods">{neighborhoods.join(', ')}{d.neighborhoods?.length > 3 ? ' +' + (d.neighborhoods.length - 3) + ' more' : ''}</div>
  <div class="card-stat">
    <span class="stat-value">{statValue}</span>
    <span class="stat-label">{statLabel}</span>
  </div>
</a>

<style>
  .district-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.15s, box-shadow 0.15s;
    background: var(--color-bg);
  }

  .district-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .card-number {
    font-family: var(--font-heading);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
  }

  .card-member {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
  }

  .card-neighborhoods {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
  }

  .card-stat {
    margin-top: 0.35rem;
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
  }

  .stat-value {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
  }

  .stat-label {
    font-family: var(--font-heading);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
</style>
