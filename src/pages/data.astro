---
/**
 * data.astro — Data Trends & Methodology page.
 * Dynamically generates trend comparison tables from all 9 district JSON
 * snapshots at build time; includes full methodology section.
 */
import Layout from '../components/Layout.astro';

import d1 from '../data/districts/district-1.json';
import d2 from '../data/districts/district-2.json';
import d3 from '../data/districts/district-3.json';
import d4 from '../data/districts/district-4.json';
import d5 from '../data/districts/district-5.json';
import d6 from '../data/districts/district-6.json';
import d7 from '../data/districts/district-7.json';
import d8 from '../data/districts/district-8.json';
import d9 from '../data/districts/district-9.json';

const allDistricts = [d1, d2, d3, d4, d5, d6, d7, d8, d9];

/* ------------------------------------------------------------------ */
/*  Build the trend data structure (3D.1)                              */
/*  For each metric, build: { vintage: { D1: value, D2: value, … } }  */
/* ------------------------------------------------------------------ */

// Collect all vintages present across any district (chronological order)
const vintageSet = new Set<string>();
allDistricts.forEach((d) => {
  d.demographics.snapshots.forEach((s: any) => {
    if (s.data && Object.values(s.data).some((v: any) => v !== null)) {
      vintageSet.add(s.vintage);
    }
  });
});
const vintages = Array.from(vintageSet).sort(); // chronological

// Helper: extract a metric value from a district's snapshot
function getMetric(district: any, vintage: string, metric: string): number | null {
  const snap = district.demographics.snapshots.find((s: any) => s.vintage === vintage);
  if (!snap || !snap.data) return null;
  return snap.data[metric] ?? null;
}

// Helper: extract an Esri metric value
function getEsriMetric(district: any, vintage: string, metric: string): number | null {
  const snap = district.demographics.snapshots.find((s: any) => s.vintage === vintage);
  if (!snap || !snap.esri_estimates) return null;
  return snap.esri_estimates[metric] ?? null;
}

// Build trend rows for a metric
type TrendRow = { vintage: string; values: (number | null)[] };
function buildTrend(metric: string): TrendRow[] {
  return vintages.map((v) => ({
    vintage: v,
    values: allDistricts.map((d) => getMetric(d, v, metric)),
  }));
}

// Build Esri trend rows for a metric
function buildEsriTrend(metric: string): TrendRow[] {
  return vintages.map((v) => ({
    vintage: v,
    values: allDistricts.map((d) => getEsriMetric(d, v, metric)),
  }));
}

// Compute change row (most recent minus previous)
function changeRow(rows: TrendRow[]): (number | null)[] {
  if (rows.length < 2) return allDistricts.map(() => null);
  const prev = rows[rows.length - 2].values;
  const curr = rows[rows.length - 1].values;
  return curr.map((c, i) => {
    if (c === null || prev[i] === null) return null;
    return c - prev[i];
  });
}

/* Build all trend sets */
const popTrend = buildTrend('total_population');
const hhTrend = buildTrend('total_households');

const pctWhiteTrend = buildTrend('pct_nh_white');
const pctBlackTrend = buildTrend('pct_nh_black');
const pctHispanicTrend = buildTrend('pct_hispanic');
const pctAsianTrend = buildTrend('pct_nh_asian');

const incomeTrend = buildTrend('median_hh_income_est');
const incomeEsri = buildEsriTrend('median_hh_income');
const rentTrend = buildTrend('median_gross_rent_est');
const rentEsri = buildEsriTrend('median_gross_rent');
const homeValueTrend = buildTrend('median_home_value_est');
const homeValueEsri = buildEsriTrend('median_home_value');
const unempTrend = buildTrend('unemployment_rate');
const unempEsri = buildEsriTrend('unemployment_rate');

/* Formatting helpers */
function fmtNum(v: number | null) { return v !== null && v !== undefined ? v.toLocaleString('en-US') : '—'; }
function fmtDollar(v: number | null) { return v !== null && v !== undefined ? '$' + v.toLocaleString('en-US') : '—'; }
function fmtPct(v: number | null) { return v !== null && v !== undefined ? v.toFixed(1) + '%' : '—'; }
function fmtChange(v: number | null, fmt: 'num' | 'dollar' | 'pct') {
  if (v === null || v === undefined) return '—';
  const sign = v > 0 ? '+' : '';
  if (fmt === 'dollar') return sign + '$' + Math.round(v).toLocaleString('en-US');
  if (fmt === 'pct') return sign + v.toFixed(1) + ' pp';
  return sign + v.toLocaleString('en-US');
}

/* Vintage history table data */
const vintageHistory = [
  { vintage: 'ACS 2017-2021', pullDate: 'Jan 2023', source: 'U.S. Census Bureau ACS 5-Year', variables: 'Population, households, income, rent, home value, unemployment, race/ethnicity', status: 'Placeholder (data not yet populated)' },
  { vintage: 'ACS 2019-2023', pullDate: 'Apr 2, 2026', source: 'U.S. Census Bureau ACS 5-Year via Census API', variables: 'Population, households, income, rent, home value, unemployment, race/ethnicity', status: 'Active — current vintage' },
  { vintage: 'Esri Current-Year', pullDate: 'Apr 2, 2026', source: 'Esri current-year estimates (Comparisons.xlsx)', variables: 'Population, income, rent, home value, unemployment, race/ethnicity', status: 'Supplemental comparison' },
];
